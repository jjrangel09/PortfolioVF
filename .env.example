# EmailJS — copia este archivo a .env.local y reemplaza con tus valores reales.
# .env.local está en .gitignore y nunca se commitea.
#
# Obtén estas claves en https://www.emailjs.com/
#   1. Service ID  → Email Services > tu servicio conectado
#   2. Template ID → Email Templates > tu plantilla
#   3. Public Key  → Account > General > Public Key
#
VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
